# APIキー・トークンなどの機密ファイル（全フォルダ共通）
.env
.env.*
*.env
*.env.*

# Playwrightセッション情報（ログインcookie等の機密）
.chatwork_auth.json
.gas_auth.json
*_auth_state.json

# Google API認証ファイル
credentials*.json
*-service-account*.json
reffort-sheets-*.json

# eBay/各種APIのOAuthトークン・キャッシュ（2026-04-29 追加・過去commit混入を発見）
**/ebay_oauth_tokens.json
**/ebay_seller_cache.json
**/oauth_tokens*.json
**/*_oauth_state.json

# 動的に生成されるトークンキャッシュ全般（2026-05-01 追加・research/ツール対応）
# tools/research/cache/ebay_app_token.json 等のApplication Tokenキャッシュを除外
**/cache/*token*.json
**/cache/*credentials*.json
**/cache/*secret*.json

# バックアップファイル（ローカル作業用・GitHub不要）
*.bak
*.backup_*

# Pythonキャッシュ
__pycache__/
*.pyc
*.pyo

# ログ・一時ファイル
*.log
error_*.log
run_log.txt

# Node.js依存パッケージ（再インストール可・リポジトリに含めない）
node_modules/
package-lock.json
yarn.lock

# OS・エディタの一時ファイル
.DS_Store
Thumbs.db
*.swp

# GAS作業の中間生成物（再生成可能・コミット不要）
_gas_b64*.txt
gas_b64_temp.txt
gas_shiire_b64*.txt
gas_shiire_content.json
big_chunk.txt
b64_ch*.txt
ch_[0-9][0-9].txt
s_[0-9][0-9].txt
_inject.js
full_push.js
part[0-9].js

# direct-sales の一時ダンプ（再生成可能）
tmp-*.html
tmp-*.csv

# データバックアップ（本番は永続ディスク側が正・ローカル管理不要）
**/data/backup_*/
**/data/backup_before_sync_*/

# PyInstaller等の展開物・解体物（再展開可能・リポジトリ不要）
*_extracted/

# Claude Code ランタイム（セッションごとに自動書き換わるロックファイル・git管理の意味なし）
.claude/scheduled_tasks.lock
